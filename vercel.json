<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FISIO365 — Panel Fisioterapeuta</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --azul: #185FA5;
    --azul-claro: #E6F1FB;
    --verde: #3B6D11;
    --verde-claro: #EAF3DE;
    --rojo: #A32D2D;
    --rojo-claro: #FCEBEB;
    --gris: #5F5E5A;
    --gris-claro: #F1EFE8;
    --borde: rgba(0,0,0,0.12);
    --radio: 12px;
    --radio-sm: 8px;
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: #f5f4f0;
    color: #1a1a1a;
    min-height: 100vh;
  }

  header {
    background: white;
    border-bottom: 0.5px solid var(--borde);
    padding: 14px 20px;
    display: flex;
    align-items: center;
    gap: 10px;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  header h1 { font-size: 17px; font-weight: 600; }
  header span { font-size: 13px; color: var(--gris); }

  .container { max-width: 680px; margin: 0 auto; padding: 20px 16px 80px; }

  /* LOGIN */
  #login-screen {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 80vh;
  }

  .login-card {
    background: white;
    border-radius: var(--radio);
    border: 0.5px solid var(--borde);
    padding: 32px 28px;
    width: 100%;
    max-width: 340px;
    text-align: center;
  }

  .login-card h2 { font-size: 20px; margin-bottom: 6px; }
  .login-card p { font-size: 14px; color: var(--gris); margin-bottom: 24px; }

  input[type=password], input[type=text], input[type=number], input[type=url], input[type=week], select, textarea {
    width: 100%;
    padding: 10px 14px;
    border: 0.5px solid var(--borde);
    border-radius: var(--radio-sm);
    font-size: 15px;
    font-family: inherit;
    background: white;
    outline: none;
    transition: border-color 0.15s;
  }

  input:focus, select:focus, textarea:focus { border-color: var(--azul); }

  .btn {
    display: block;
    width: 100%;
    padding: 12px;
    border: none;
    border-radius: var(--radio-sm);
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.15s, transform 0.1s;
  }
  .btn:active { transform: scale(0.98); }
  .btn-primary { background: var(--azul); color: white; }
  .btn-primary:hover { opacity: 0.9; }
  .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }
  .btn-success { background: var(--verde); color: white; }
  .btn-success:hover { opacity: 0.9; }
  .btn-success:disabled { opacity: 0.5; cursor: not-allowed; }
  .btn-outline {
    background: none;
    border: 0.5px dashed var(--borde);
    color: var(--gris);
    font-weight: 400;
  }
  .btn-outline:hover { background: var(--gris-claro); }

  .card {
    background: white;
    border-radius: var(--radio);
    border: 0.5px solid var(--borde);
    padding: 18px;
    margin-bottom: 14px;
  }

  .card-title {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--gris);
    margin-bottom: 14px;
  }

  .field { margin-bottom: 12px; }
  .field label { display: block; font-size: 13px; color: var(--gris); margin-bottom: 5px; }

  .dias-wrap { display: flex; flex-wrap: wrap; gap: 8px; }
  .dia-pill {
    padding: 7px 16px;
    border-radius: 999px;
    border: 0.5px solid var(--borde);
    font-size: 14px;
    cursor: pointer;
    background: none;
    font-family: inherit;
    transition: all 0.15s;
  }
  .dia-pill.on { background: var(--azul-claro); border-color: var(--azul); color: var(--azul); font-weight: 600; }

  .ej-card {
    background: #fafaf8;
    border: 0.5px solid var(--borde);
    border-radius: var(--radio-sm);
    padding: 14px;
    margin-bottom: 10px;
  }

  .ej-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }

  .ej-numero {
    font-size: 13px;
    font-weight: 600;
    color: var(--azul);
  }

  .btn-eliminar {
    background: none;
    border: none;
    color: var(--rojo);
    cursor: pointer;
    font-size: 20px;
    line-height: 1;
    padding: 0 4px;
  }

  .grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .grid3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; }

  input[type=number] { text-align: center; }

  .resumen {
    background: var(--verde-claro);
    border: 0.5px solid #C0DD97;
    border-radius: var(--radio-sm);
    padding: 10px 14px;
    font-size: 13px;
    color: var(--verde);
    margin-bottom: 14px;
    display: none;
  }

  .toast {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 22px;
    border-radius: var(--radio-sm);
    font-size: 14px;
    font-weight: 500;
    display: none;
    z-index: 999;
    white-space: nowrap;
    box-shadow: 0 4px 20px rgba(0,0,0,0.15);
  }

  .toast.ok { background: var(--verde); color: var(--verde-claro); }
  .toast.err { background: var(--rojo); color: var(--rojo-claro); }

  .error-msg {
    background: var(--rojo-claro);
    color: var(--rojo);
    padding: 10px 14px;
    border-radius: var(--radio-sm);
    font-size: 13px;
    margin-top: 10px;
    display: none;
  }

  #main-screen { display: none; }

  .paciente-info {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: var(--azul-claro);
    color: var(--azul);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 15px;
    flex-shrink: 0;
  }

  .paciente-nombre { font-size: 15px; font-weight: 600; }
  .paciente-tel { font-size: 13px; color: var(--gris); }

  select option:disabled { color: #aaa; }

  @media (max-width: 400px) {
    .grid3 { grid-template-columns: 1fr 1fr; }
  }
</style>
</head>
<body>

<header>
  <div>
    <h1>FISIO365</h1>
  </div>
  <span id="header-sub" style="margin-left:auto;">Panel fisioterapeuta</span>
</header>

<!-- LOGIN -->
<div id="login-screen">
  <div class="container" style="display:flex;align-items:center;justify-content:center;min-height:70vh;">
    <div class="login-card">
      <h2>Acceso fisio</h2>
      <p>Introduce tu contraseña para entrar al panel</p>
      <div class="field">
        <input type="password" id="pwd-input" placeholder="Contraseña" autocomplete="current-password" />
      </div>
      <div class="error-msg" id="login-error">Contraseña incorrecta</div>
      <button class="btn btn-primary" id="btn-login" onclick="doLogin()" style="margin-top:16px;">Entrar</button>
    </div>
  </div>
</div>

<!-- PANEL PRINCIPAL -->
<div id="main-screen">
  <div class="container">

    <!-- PACIENTE -->
    <div class="card">
      <div class="card-title">Paciente</div>
      <div class="field">
        <label>Seleccionar paciente</label>
        <select id="paciente-select" onchange="onPacienteChange()">
          <option value="">Cargando pacientes...</option>
        </select>
      </div>
      <div id="paciente-preview" style="display:none; margin-top:10px;">
        <div class="paciente-info">
          <div class="avatar" id="paciente-avatar">--</div>
          <div>
            <div class="paciente-nombre" id="paciente-nombre-display">--</div>
            <div class="paciente-tel" id="paciente-tel-display">--</div>
          </div>
        </div>
      </div>
    </div>

    <!-- FECHAS -->
    <div class="card">
      <div class="card-title">Fechas del programa</div>
      <div class="field">
        <label>Semana</label>
        <input type="week" id="semana-input" onchange="updateResumen()" />
      </div>
      <div class="field">
        <label>Dias</label>
        <div class="dias-wrap" id="dias-wrap">
          <button class="dia-pill" data-d="1" onclick="toggleDia(this)">Lun</button>
          <button class="dia-pill" data-d="2" onclick="toggleDia(this)">Mar</button>
          <button class="dia-pill" data-d="3" onclick="toggleDia(this)">Mie</button>
          <button class="dia-pill" data-d="4" onclick="toggleDia(this)">Jue</button>
          <button class="dia-pill" data-d="5" onclick="toggleDia(this)">Vie</button>
          <button class="dia-pill" data-d="6" onclick="toggleDia(this)">Sab</button>
        </div>
      </div>
    </div>

    <!-- EJERCICIOS -->
    <div class="card">
      <div class="card-title">Ejercicios</div>
      <div id="ejercicios-lista"></div>
      <button class="btn btn-outline" onclick="addEjercicio()" style="margin-top:4px;">+ Añadir ejercicio</button>
    </div>

    <!-- RESUMEN -->
    <div class="resumen" id="resumen"></div>

    <!-- GUARDAR -->
    <button class="btn btn-success" id="btn-guardar" onclick="guardar()">
      Guardar programa
    </button>

  </div>
</div>

<div class="toast" id="toast"></div>

<script>
let pwd = '';
let pacientes = [];
let ejCount = 0;
let diasOn = new Set();

// ---- LOGIN ----
document.getElementById('pwd-input').addEventListener('keydown', e => {
  if (e.key === 'Enter') doLogin();
});

async function doLogin() {
  const input = document.getElementById('pwd-input').value.trim();
  if (!input) return;

  const btn = document.getElementById('btn-login');
  btn.disabled = true;
  btn.textContent = 'Verificando...';

  try {
    const res = await fetch(`/api/pacientes?pwd=${encodeURIComponent(input)}`);
    const data = await res.json();

    if (data.ok) {
      pwd = input;
      pacientes = data.pacientes;
      renderPacientes();
      document.getElementById('login-screen').style.display = 'none';
      document.getElementById('main-screen').style.display = 'block';
      initSemana();
      addEjercicio();
    } else {
      document.getElementById('login-error').style.display = 'block';
    }
  } catch(e) {
    document.getElementById('login-error').textContent = 'Error de conexión';
    document.getElementById('login-error').style.display = 'block';
  }

  btn.disabled = false;
  btn.textContent = 'Entrar';
}

// ---- PACIENTES ----
function renderPacientes() {
  const sel = document.getElementById('paciente-select');
  sel.innerHTML = '<option value="">Seleccionar paciente...</option>' +
    pacientes.map(p => `<option value="${p.id}" data-nombre="${p.nombre}" data-tel="${p.telefono}">${p.nombre}</option>`).join('');
}

function onPacienteChange() {
  const sel = document.getElementById('paciente-select');
  const opt = sel.options[sel.selectedIndex];
  const preview = document.getElementById('paciente-preview');

  if (!sel.value) { preview.style.display = 'none'; return; }

  const nombre = opt.dataset.nombre;
  const tel = opt.dataset.tel;
  const iniciales = nombre.split(' ').map(w => w[0]).slice(0,2).join('').toUpperCase();

  document.getElementById('paciente-avatar').textContent = iniciales;
  document.getElementById('paciente-nombre-display').textContent = nombre;
  document.getElementById('paciente-tel-display').textContent = tel || 'Sin teléfono';
  preview.style.display = 'block';
  updateResumen();
}

// ---- SEMANA ----
function initSemana() {
  const hoy = new Date();
  const year = hoy.getFullYear();
  const d = new Date(Date.UTC(year, 0, 4));
  const dayNum = d.getUTCDay() || 7;
  d.setUTCDate(d.getUTCDate() - dayNum + 1);
  const diff = hoy - d;
  const week = Math.ceil((diff / 86400000 + 1) / 7);
  document.getElementById('semana-input').value = `${year}-W${String(week).padStart(2,'0')}`;
}

function toggleDia(btn) {
  const d = btn.dataset.d;
  if (diasOn.has(d)) { diasOn.delete(d); btn.classList.remove('on'); }
  else { diasOn.add(d); btn.classList.add('on'); }
  updateResumen();
}

function getFechas() {
  const semana = document.getElementById('semana-input').value;
  if (!semana) return [];
  const [year, wStr] = semana.split('-W');
  const week = parseInt(wStr);
  const jan4 = new Date(parseInt(year), 0, 4);
  const lunes = new Date(jan4);
  lunes.setDate(jan4.getDate() - (jan4.getDay() || 7) + 1 + (week - 1) * 7);
  return [...diasOn].sort().map(d => {
    const f = new Date(lunes);
    f.setDate(lunes.getDate() + (parseInt(d) - 1));
    return f.toISOString().split('T')[0];
  });
}

// ---- EJERCICIOS ----
function addEjercicio() {
  ejCount++;
  const n = ejCount;
  const lista = document.getElementById('ejercicios-lista');
  const div = document.createElement('div');
  div.className = 'ej-card';
  div.id = `ej-${n}`;
  div.innerHTML = `
    <div class="ej-header">
      <span class="ej-numero">Ejercicio ${n}</span>
      <button class="btn-eliminar" onclick="removeEj(${n})" title="Eliminar">&times;</button>
    </div>
    <div class="field">
      <label>Nombre</label>
      <input type="text" id="en-${n}" placeholder="Ej: Sentadilla, Puente de glúteos..." />
    </div>
    <div class="grid3">
      <div class="field">
        <label>Series</label>
        <input type="number" id="es-${n}" value="3" min="1" />
      </div>
      <div class="field">
        <label>Reps</label>
        <input type="number" id="er-${n}" value="10" min="0" />
      </div>
      <div class="field">
        <label>Dur. (seg)</label>
        <input type="number" id="ed-${n}" value="0" min="0" />
      </div>
    </div>
    <div class="grid2">
      <div class="field">
        <label>Descanso (seg)</label>
        <input type="number" id="edes-${n}" value="30" min="0" />
      </div>
      <div class="field">
        <label>Zona corporal</label>
        <input type="text" id="ez-${n}" placeholder="Ej: Lumbar, Rodilla..." />
      </div>
    </div>
    <div class="field">
      <label>Indicaciones para el paciente</label>
      <input type="text" id="edesc-${n}" placeholder="Ej: Mantén la espalda recta..." />
    </div>
    <div class="field">
      <label>Video YouTube (URL)</label>
      <input type="url" id="eurl-${n}" placeholder="https://youtube.com/watch?v=..." />
    </div>
  `;
  lista.appendChild(div);
  updateResumen();
}

function removeEj(n) {
  document.getElementById(`ej-${n}`)?.remove();
  updateResumen();
}

function getEjercicios() {
  return [...document.querySelectorAll('.ej-card')]
    .map(card => {
      const n = card.id.replace('ej-', '');
      const nombre = document.getElementById(`en-${n}`)?.value?.trim();
      if (!nombre) return null;
      return {
        nombre,
        series: parseInt(document.getElementById(`es-${n}`)?.value) || 0,
        reps: parseInt(document.getElementById(`er-${n}`)?.value) || 0,
        duracion: parseInt(document.getElementById(`ed-${n}`)?.value) || 0,
        descanso: parseInt(document.getElementById(`edes-${n}`)?.value) || 0,
        zona: document.getElementById(`ez-${n}`)?.value?.trim() || '',
        descripcion: document.getElementById(`edesc-${n}`)?.value?.trim() || '',
        youtubeUrl: document.getElementById(`eurl-${n}`)?.value?.trim() || ''
      };
    })
    .filter(Boolean);
}

function updateResumen() {
  const fechas = getFechas();
  const ejercicios = getEjercicios();
  const res = document.getElementById('resumen');
  if (fechas.length > 0 && ejercicios.length > 0) {
    const total = fechas.length * ejercicios.length;
    res.style.display = 'block';
    res.textContent = `Se guardarán ${total} registros: ${ejercicios.length} ejercicio${ejercicios.length > 1 ? 's' : ''} × ${fechas.length} dia${fechas.length > 1 ? 's' : ''}`;
  } else {
    res.style.display = 'none';
  }
}

// ---- GUARDAR ----
async function guardar() {
  const sel = document.getElementById('paciente-select');
  const pacienteId = sel.value;
  const pacienteNombre = sel.options[sel.selectedIndex]?.dataset?.nombre || '';

  if (!pacienteId) { toast('Selecciona un paciente', false); return; }

  const fechas = getFechas();
  if (fechas.length === 0) { toast('Selecciona la semana y al menos un día', false); return; }

  const ejercicios = getEjercicios();
  if (ejercicios.length === 0) { toast('Añade al menos un ejercicio con nombre', false); return; }

  const btn = document.getElementById('btn-guardar');
  btn.disabled = true;
  btn.textContent = 'Guardando...';

  try {
    const res = await fetch('/api/programa', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ pwd, pacienteId, pacienteNombre, fechas, ejercicios })
    });

    const data = await res.json();

    if (data.ok) {
      toast(`Guardado: ${data.creados} registros en Airtable`, true);
    } else {
      toast(data.error || 'Error al guardar', false);
    }
  } catch(e) {
    toast('Error de conexión', false);
  }

  btn.disabled = false;
  btn.textContent = 'Guardar programa';
}

// ---- TOAST ----
function toast(msg, ok = true) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast ' + (ok ? 'ok' : 'err');
  t.style.display = 'block';
  setTimeout(() => t.style.display = 'none', 3500);
}
</script>

</body>
</html>
